# Copy to .env (gitignored). No secrets belong in this repo.
#
# Data source toggle for src/services/dataverse.js:
#   true  → in-memory MOCK (default; no backend, no client data)
#   false → live/sandbox Dataverse + Copilot via the generated services
# Only flip to false against a SANDBOX org with synthetic data.
# When false, the chat calls the REAL Copilot Studio agent in-tenant; the roster
# and history still use the in-memory store until the Dataverse tables exist.
VITE_USE_MOCK=true

# Optional: pin which Copilot Studio agent invokeAgent() calls. If unset, the
# app auto-discovers the first agent via ListCopilots(). Set this once you have
# multiple agents (use the agent's schema name / bot id from Copilot Studio).
# VITE_COPILOT_ID=

