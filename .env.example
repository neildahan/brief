# Copy to .env (gitignored). No secrets belong in this repo.
#
# Data source toggle for src/services/dataverse.js:
#   true  → in-memory MOCK (default; no backend, no client data)
#   false → live/sandbox Dataverse + Copilot via the generated services
# Only flip to false against a SANDBOX org with synthetic data.
VITE_USE_MOCK=true
